# Copiar este archivo a .env y completar con tus propios valores.
# .env NO debe subirse al repositorio (ver .gitignore).

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu_contraseña_de_neo4j

# API key gratuita en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini
